generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ═══════════════════════════════════════════════════════════════
// Auth.js tables — required for authentication
// Do not rename these models or their fields; Auth.js expects this exact schema.
// ═══════════════════════════════════════════════════════════════

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?

  accounts Account[]
  sessions Session[]
  hearts   Heart[]

  @@map("users")
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
  @@map("verification_tokens")
}

// ═══════════════════════════════════════════════════════════════
// VibéShop tables
// After editing, run: npm run db:push
// ═══════════════════════════════════════════════════════════════

model Post {
  id             String    @id @default(cuid())
  wpPostId       Int?      @unique
  title          String
  displayTitle   String?   // AI-generated desire name: "Garden Party in Florals"
  date           DateTime
  publishedAt    DateTime?
  url            String    @unique
  slug           String    @unique
  outfitImageUrl String?
  season         String?
  rawHtml        String?   @db.Text
  ingestStatus   String    @default("pending")
  ingestError    String?   @db.Text
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  products        Product[]
  vibeAssignments VibeAssignment[]
  visionData      VisionData?

  @@index([date])
  @@index([season])
  @@index([ingestStatus])
  @@map("posts")
}

model Product {
  id              String    @id @default(cuid())
  postId          String
  brand           String?
  itemName        String?
  rawText         String
  affiliateUrl    String
  productImageUrl String?
  garmentType     String?
  sortOrder       Int       @default(0)
  isAlternative   Boolean   @default(false)
  isHeroPiece     Boolean   @default(false)
  parentProductId String?
  price           Float?
  retailerName    String?
  retailerUrl     String?
  retailerDomain  String?
  linkAlive       Boolean   @default(true)
  lastCheckedAt   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  post          Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  parentProduct Product?  @relation("ProductAlternatives", fields: [parentProductId], references: [id])
  alternatives  Product[] @relation("ProductAlternatives")

  @@index([postId])
  @@index([brand])
  @@index([garmentType])
  @@index([postId, isAlternative])
  @@index([brand, itemName])
  @@map("products")
}

model Vibe {
  id            String    @id @default(cuid())
  name          String    @unique
  slug          String    @unique
  tagline       String?
  introText     String?   @db.Text
  type          String    @default("auto") // "auto" | "editorial" | "smart"
  filterRules   Json?     // For smart vibes: { dateRange?, brand?, color?, formality?, season? }
  stylingTips   String?   @db.Text // "How to wear this vibe" — guide voice
  occasionText  String?   @db.Text // Seasonal/occasion context paragraph
  accentColor   String?
  coverImageUrl String?
  centroid      Json?
  sortOrder     Int       @default(0)
  approvedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  vibeAssignments VibeAssignment[]

  @@map("vibes")
}

model VibeAssignment {
  id              String   @id @default(cuid())
  postId          String
  vibeId          String
  confidenceScore Float?
  assignedBy      String   @default("ai")
  createdAt       DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  vibe Vibe @relation(fields: [vibeId], references: [id], onDelete: Cascade)

  @@unique([postId, vibeId])
  @@index([vibeId])
  @@index([postId])
  @@map("vibe_assignments")
}

model VisionData {
  id           String    @id @default(cuid())
  postId       String    @unique
  garments     Json?
  palette      Json?
  mood         String?
  season       String?
  formality    String?
  setting      String?
  vibeKeywords Json?
  stylingNotes String?   @db.Text
  embedding    Json?
  modelVersion String?
  processedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@map("vision_data")
}

model Heart {
  id        String   @id @default(cuid())
  userId    String
  itemType  String   // "look" | "product" | "vibe"
  itemId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, itemType, itemId])
  @@index([itemType, itemId])
  @@index([userId])
  @@map("hearts")
}

model IngestLog {
  id           String    @id @default(cuid())
  runType      String
  status       String
  postsFound   Int       @default(0)
  postsNew     Int       @default(0)
  postsUpdated Int       @default(0)
  postsFailed  Int       @default(0)
  errorLog     Json?
  startedAt    DateTime  @default(now())
  completedAt  DateTime?

  @@index([runType])
  @@index([startedAt])
  @@map("ingest_logs")
}
